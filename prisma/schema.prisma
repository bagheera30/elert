// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma" // Sesuaikan path output jika perlu
  engineType = "client"                 // <-- Konfirmasi baris ini ADA
}

datasource db {
  provider = "postgresql"               // atau provider Anda

}

model Alert {
  id        Int      @id @default(autoincrement())
  type      String   // 'follow', 'donate', 'sub', 'raid', 'host'
  username  String
  message   String?
  amount    String?
  image     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead, createdAt])
  @@map("alerts")
}